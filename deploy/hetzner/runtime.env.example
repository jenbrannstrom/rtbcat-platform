# Non-secret runtime configuration. Install the real file root-owned mode 0600.
# Secret values stay in Google Secret Manager or dedicated host secret files.

GCP_PROJECT_ID=replace-with-retained-gcp-project
GOOGLE_CLOUD_PROJECT=replace-with-retained-gcp-project
BIGQUERY_PROJECT_ID=replace-with-retained-gcp-project
BIGQUERY_DATASET=replace-with-dataset
CATSCAN_BQ_PROJECT=replace-with-retained-gcp-project
CATSCAN_BQ_DATASET=replace-with-dataset
CATSCAN_GCS_BUCKET=replace-with-bucket
RAW_PARQUET_BUCKET=replace-with-bucket

SECRETS_NAME_PREFIX=catscan
CATSCAN_ENABLE_PASSWORD_LOGIN=true
CATSCAN_ENABLE_GOOGLE_LOGIN=false
CATSCAN_ENABLE_AUTHING_LOGIN=false
CATSCAN_DEFAULT_LOGIN_METHOD=password
CATSCAN_REQUIRE_BOOTSTRAP_TOKEN=true
CATSCAN_SINGLE_USER_MODE=false

# Shadow mode must never own scheduled writes.
CATSCAN_ENABLE_GMAIL_IMPORT_SCHEDULER=false
CATSCAN_ENABLE_PRECOMPUTE_SCHEDULER=false
CATSCAN_ENABLE_CREATIVE_CACHE_SCHEDULER=false
CATSCAN_ENABLE_LANGUAGE_AI=false
CATSCAN_ENABLE_CLUSTERING_AI=false
CATSCAN_REQUIRE_OAUTH_CLIENT_SECRET_IN_API=false
CATSCAN_READ_ONLY_SHADOW=true

ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
PRECOMPUTE_REFRESH_DAYS=2
PRECOMPUTE_REFRESH_MAX_AGE_HOURS=36
DATA_HEALTH_QUERY_TIMEOUT_MS=30000
