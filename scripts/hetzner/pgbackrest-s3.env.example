# Copy to a root-owned mode-0600 file outside the repository, for example:
#   /etc/rtbcat/pgbackrest-s3.env
# The backup provider must be independent of the Hetzner Singapore failure
# domain. Values below are placeholders, not real credentials.

PGBACKREST_S3_BUCKET=replace-me
PGBACKREST_S3_ENDPOINT=s3.example.invalid
PGBACKREST_S3_REGION=replace-me
PGBACKREST_S3_KEY=replace-me
PGBACKREST_S3_KEY_SECRET=replace-me
PGBACKREST_CIPHER_PASS=replace-with-a-long-random-backup-encryption-passphrase

PGBACKREST_S3_URI_STYLE=host
PGBACKREST_REPO_PATH=/rtbcat/postgresql
PGBACKREST_RETENTION_FULL=2
PGBACKREST_RETENTION_DIFF=6
