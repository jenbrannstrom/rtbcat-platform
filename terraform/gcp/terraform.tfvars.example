# Cat-Scan GCP Terraform Variables
# Copy this file to terraform.tfvars and fill in your values
#
# terraform.tfvars is gitignored - never commit credentials

# Required: Your GCP Project ID
gcp_project = "your-project-id"

# Region and zone (europe-west1 recommended for Google API proximity)
gcp_region = "europe-west1"
gcp_zone   = "europe-west1-b"

# Application settings
app_name    = "catscan"
environment = "production"

# VM size (e2-medium is good for moderate load)
machine_type   = "e2-medium"
boot_disk_size = 30

# Domain name (required for HTTPS)
domain_name  = "scan.rtb.cat"
enable_https = true

# SSH access (leave empty for IAP-only access - more secure)
# Only add your IP if you need direct SSH access
allowed_ssh_cidrs = []
# allowed_ssh_cidrs = ["1.2.3.4/32"]  # Your IP only

# GitHub repository
github_repo   = "https://github.com/jenbrannstrom/rtbcat-platform.git"
github_branch = "unified-platform"

# Optional: Cloudflare DNS management
# Leave empty if managing DNS manually
cloudflare_api_token = ""
cloudflare_zone_id   = ""

# =============================================================================
# REQUIRED: Google OAuth Authentication
# =============================================================================
# All users must authenticate with Google before accessing Cat-Scan.
# This eliminates default passwords and leverages Google's security.
#
# Setup instructions:
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Click "+ CREATE CREDENTIALS" → "OAuth client ID"
# 3. Application type: "Web application"
# 4. Name: "Cat-Scan"
# 5. Authorized redirect URIs: https://YOUR_DOMAIN/oauth2/callback
# 6. Copy the Client ID and Client Secret below

google_oauth_client_id     = "123456789-xxxxxxxxxx.apps.googleusercontent.com"
google_oauth_client_secret = "GOCSPX-xxxxxxxxxx"

# Optional: Restrict access to specific email domains
# Leave empty to allow any Google account
# Example: ["company.com", "partner.org"]
allowed_email_domains = []

# =============================================================================
# Analytics storage + BigQuery
# =============================================================================

# Raw parquet bucket for analytics ingestion
raw_parquet_bucket_name   = "rtbcat-raw-parquet"
raw_parquet_lifecycle_days = 180

# BigQuery dataset + raw facts table
bigquery_dataset_id         = "rtbcat_analytics"
bigquery_location           = "EU"
bigquery_raw_facts_table_id = "raw_facts"

# =============================================================================
# Cloud SQL (Postgres)
# =============================================================================

cloudsql_database_version  = "POSTGRES_15"
cloudsql_tier              = "db-perf-optimized-N-2"
cloudsql_availability_type = "REGIONAL"
cloudsql_disk_size_gb      = 100
cloudsql_database_name     = "rtbcat_serving"
cloudsql_user_name         = "rtbcat_serving"
