gcp_project = "your-project-id"
gcp_region  = "asia-east1"
gcp_zone    = "asia-east1-a"

app_name    = "catscan"
environment = "production"

machine_type  = "e2-medium"
boot_disk_size = 80

domain_name  = ""
enable_https = false

github_repo   = "https://github.com/YOUR_ORG/rtbcat-platform.git"
github_branch = "main"

google_oauth_client_id     = "YOUR_CLIENT_ID.apps.googleusercontent.com"
allowed_email_domains      = ["example.com"]

service_account_email   = "catscan-sa@your-project-id.iam.gserviceaccount.com"
artifact_registry_domain = "asia-east1-docker.pkg.dev"

gcs_bucket = "your-catscan-data-bucket"

# SG2 dedicated staging database isolation
enable_dedicated_serving_db = false
cloudsql_instance_name      = "catscan-production-sg2-serving"
cloudsql_database_version   = "POSTGRES_15"
cloudsql_tier               = "db-custom-1-3840"
cloudsql_availability_type  = "ZONAL"
cloudsql_disk_size_gb       = 118
cloudsql_database_name      = "rtbcat_serving_sg2"
serving_db_secret_id        = "catscan-serving-db-credentials-sg2"
