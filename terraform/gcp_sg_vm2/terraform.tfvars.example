gcp_project = "your-project-id"
gcp_region  = "asia-east1"
gcp_zone    = "asia-east1-a"

app_name    = "catscan"
environment = "production"

machine_type  = "e2-medium"
boot_disk_size = 80

domain_name  = ""
enable_https = false

github_repo   = "https://github.com/YOUR_ORG/rtbcat-platform.git"
github_branch = "main"

google_oauth_client_id     = "YOUR_CLIENT_ID.apps.googleusercontent.com"
google_oauth_client_secret = "YOUR_CLIENT_SECRET"
allowed_email_domains      = ["example.com"]

service_account_email   = "catscan-sa@your-project-id.iam.gserviceaccount.com"
artifact_registry_domain = "asia-east1-docker.pkg.dev"

gcs_bucket = "your-catscan-data-bucket"
