# Cat-Scan Caddyfile
# Automatic HTTPS with Let's Encrypt + Optional Basic Auth

{$DOMAIN:localhost} {
    # Login page - no auth required
    handle /login {
        root * /srv
        file_server
        rewrite * /login.html
    }

    # Health check - no auth for load balancers
    handle /health {
        reverse_proxy api:8000
    }

    # Check for valid auth cookie (set CATSCAN_AUTH_COOKIE env var)
    @authenticated {
        header_regexp Cookie catscan_auth={$CATSCAN_AUTH_COOKIE}
    }

    # Redirect to login if not authenticated
    @not_authenticated {
        not header_regexp Cookie catscan_auth={$CATSCAN_AUTH_COOKIE}
    }

    handle @not_authenticated {
        redir * /login
    }

    # Authenticated users get access
    handle @authenticated {
        # API routes - proxy to FastAPI
        handle /api/* {
            uri strip_prefix /api
            reverse_proxy api:8000
        }

        # Dashboard
        handle {
            reverse_proxy dashboard:3000
        }
    }

    # Security headers
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
    }

    # Logging
    log {
        output stdout
        format console
    }
}
