# Cat-Scan Caddyfile
# Automatic HTTPS with Let's Encrypt
# Authentication is handled by the backend via session cookies

{$DOMAIN:localhost} {
    # Health check - no auth for load balancers
    handle /health {
        reverse_proxy api:8000
    }

    # API docs - publicly accessible
    handle /docs* {
        reverse_proxy api:8000
    }
    handle /openapi.json {
        reverse_proxy api:8000
    }
    handle /redoc* {
        reverse_proxy api:8000
    }

    # API routes - proxy to FastAPI (includes /api/auth/* endpoints)
    # Backend handles authentication via session cookies
    handle /api/* {
        uri strip_prefix /api
        reverse_proxy api:8000
    }

    # Dashboard - all routes go to Next.js (including /login)
    # Frontend handles redirects based on auth state
    handle {
        reverse_proxy dashboard:3000
    }

    # Security headers
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
    }

    # Logging
    log {
        output stdout
        format console
    }
}
