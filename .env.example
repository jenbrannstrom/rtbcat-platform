# Cat-Scan Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# =============================================================================
# REQUIRED - Core Application
# =============================================================================

# Path to Google service account JSON for Authorized Buyers API
GOOGLE_APPLICATION_CREDENTIALS=~/.catscan/credentials/google-credentials.json

# PostgreSQL connection (Cloud SQL via Auth Proxy)
# POSTGRES_DSN=postgresql://user:pass@localhost:5432/rtbcat_serving
# POSTGRES_SERVING_DSN=postgresql://user:pass@localhost:5432/rtbcat_serving

# =============================================================================
# OPTIONAL - Authentication (Production)
# =============================================================================

# Enable OAuth2 Proxy for Google login (recommended for production)
OAUTH2_PROXY_ENABLED=false

# Frontend login method toggles (dashboard build-time flags)
# Set to true to show the corresponding button on /login
# NEXT_PUBLIC_ENABLE_GOOGLE_LOGIN=false
# NEXT_PUBLIC_ENABLE_AUTHING_LOGIN=false

# API key for programmatic access (generate a random 32+ character string)
# CATSCAN_API_KEY=your-random-api-key-here

# --- Authing OIDC Authentication ---
# Get these from your Authing application settings
# AUTHING_APP_ID=your-authing-app-id
# AUTHING_APP_SECRET=your-authing-app-secret
# AUTHING_ISSUER=https://your-pool.authing.cn/oidc

# =============================================================================
# OPTIONAL - AI Features
# =============================================================================

# Google Gemini API key for language detection in creatives
# Get from: https://makersuite.google.com/app/apikey
# GEMINI_API_KEY=

# Anthropic API key for AI-powered campaign clustering
# Get from: https://console.anthropic.com/
# ANTHROPIC_API_KEY=

# =============================================================================
# OPTIONAL - Gmail Auto-Import
# =============================================================================

# Secret token for Gmail import webhook (generate a random string)
# GMAIL_IMPORT_SECRET=

# Secret token for creative cache refresh webhook (generate a random string)
# CREATIVE_CACHE_REFRESH_SECRET=

# Comma-separated seat IDs to import for
# CATSCAN_GMAIL_SEAT_IDS=1234567890,0987654321

# Gmail label to search for CSV attachments
# CATSCAN_GMAIL_LABEL=CatScan-Reports

# =============================================================================
# OPTIONAL - S3 Archive (for CSV backup)
# =============================================================================

# Enable S3 archiving of imported CSVs
# CATSCAN_S3_ARCHIVE=false
# CATSCAN_S3_BUCKET=your-bucket-name
# CATSCAN_S3_REGION=eu-central-1

# =============================================================================
# OPTIONAL - Performance Tuning
# =============================================================================

# Batch size for CSV imports (lower = less memory, slower)
# CATSCAN_IMPORT_BATCH_SIZE=1000

# Data retention in days (older data is cleaned up)
# CATSCAN_RETENTION_DAYS=90

# CORS allowed origins (comma-separated, for custom deployments)
# ALLOWED_ORIGINS=https://your-domain.com

# =============================================================================
# OPTIONAL - Secrets Backend (Multi-Cloud)
# =============================================================================

# Default is env (reads plain env vars directly)
# Supported values: env, gcp, aws, alibaba
# SECRETS_BACKEND=env

# If true (default), explicit env vars override remote secret backend values
# SECRETS_PREFER_ENV=true

# Secret name prefix for remote backends (logical key PRECOMPUTE_REFRESH_SECRET
# becomes <prefix>-precompute-refresh-secret unless overridden)
# SECRETS_NAME_PREFIX=catscan

# Optional per-key secret ID override (examples):
# SECRET_ID_PRECOMPUTE_REFRESH_SECRET=my-custom-secret-name
# SECRET_ID_GMAIL_IMPORT_SECRET=my-gmail-secret

# GCP Secret Manager settings
# GCP_PROJECT_ID=your-gcp-project

# AWS Secrets Manager settings
# AWS_REGION=ap-southeast-1

# Alibaba Cloud KMS/Secrets Manager settings
# ALIBABA_REGION_ID=cn-hangzhou
# ALIBABA_ACCESS_KEY_ID=your-ak
# ALIBABA_ACCESS_KEY_SECRET=your-sk
# ALIBABA_KMS_ENDPOINT=kms.cn-hangzhou.aliyuncs.com

# =============================================================================
# OPTIONAL - App Metadata
# =============================================================================

# App version (auto-set from VERSION file in production)
# APP_VERSION=0.9.0
